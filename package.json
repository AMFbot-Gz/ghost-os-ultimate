{
  "name": "ghost-os-ultimate",
  "version": "1.0.0",
  "description": "Ghost OS Ultimate — Agent autonome hybride unifié (LaRuche + PICO-RUCHE)",
  "bin": {
    "ghost": "./bin/ghost.js",
    "ghost-skill": "./bin/laruche-skill-runner.js",
    "laruche": "./bin/laruche.js"
  },
  "main": "src/queen_oss.js",
  "type": "module",
  "scripts": {
    "start": "pm2 start ecosystem.config.js --env production",
    "dev": "STANDALONE_MODE=true node src/queen_oss.js",
    "ultimate": "GHOST_OS_MODE=ultimate STANDALONE_MODE=true node src/queen_oss.js",
    "lite": "GHOST_OS_MODE=lite STANDALONE_MODE=true node src/queen_oss.js",
    "build": "tsc",
    "hud": "electron interfaces/hud/main.js",
    "dash": "cd interfaces/dashboard && vite",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/jest/unit/",
    "test:smoke": "node tests/jest/smoke.js",
    "test:e2e": "npx playwright test tests/jest/e2e/",
    "test:python": "python3 -m pytest tests/pytest/ -v --tb=short",
    "test:all": "npm test && npm run test:python",
    "setup": "node runtime/deployment/auto_deployment.js",
    "status": "pm2 status",
    "logs": "pm2 logs ghost-os-ultimate",
    "standalone": "STANDALONE_MODE=true node src/queen_oss.js",
    "health": "bash scripts/health_check.sh",
    "health:watch": "bash scripts/health_check.sh --watch 10",
    "health:json": "bash scripts/health_check.sh --json",
    "phase-check": "bash scripts/phase_check.sh",
    "install-mlx": "bash scripts/install_mlx.sh",
    "doctor": "bash scripts/phase_check.sh",
    "agent:start": "python3 start_agent.py",
    "agent:stop": "python3 stop_agent.py",
    "agent:status": "curl -s http://localhost:8001/status | python3 -m json.tool",
    "agent:mission": "curl -s -X POST http://localhost:8001/mission -H 'Content-Type: application/json' -d",
    "marketplace": "node -e \"import('./ecosystem/marketplace/skills_marketplace.js').then(m => new m.SkillsMarketplace().getStats()).then(console.log)\""
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@jitsi/robotjs": "^0.6.21",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@shopify/shopify-api": "^13.0.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.8.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "chromadb": "^1.8.0",
    "commander": "^12.0.0",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.0.0",
    "execa": "^9.5.1",
    "fs-extra": "^11.2.0",
    "googleapis": "^171.4.0",
    "hono": "^4.11.7",
    "jimp": "^0.22.12",
    "js-yaml": "^4.1.1",
    "node-cron": "^3.0.0",
    "ora": "^8.1.1",
    "peerjs": "^1.5.0",
    "pm2": "^5.3.0",
    "qrcode": "^1.5.0",
    "sql.js": "^1.12.0",
    "systeminformation": "^5.22.0",
    "telegraf": "^4.16.0",
    "tiktoken": "^1.0.0",
    "winston": "^3.13.0",
    "ws": "^8.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "jest": "^29.0.0",
    "playwright": "^1.40.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
