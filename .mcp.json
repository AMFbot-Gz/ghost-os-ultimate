{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/wiaamhadara/ghost-os-ultimate",
        "/Users/wiaamhadara/LaRuche",
        "/Users/wiaamhadara/Projects",
        "/Users/wiaamhadara/Desktop",
        "/Users/wiaamhadara/Downloads"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "queen-terminal": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/terminal_mcp.js"]
    },
    "skills": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/skill_factory_mcp.js"]
    },
    "vision": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/vision_mcp.js"]
    },
    "vault": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/vault_mcp.js"]
    },
    "os-control": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/os_control_mcp.js"]
    },
    "pencil": {
      "type": "stdio",
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-x64",
      "args": ["--app", "desktop"],
      "env": {}
    },
    "omega": {
      "type": "stdio",
      "command": "python3",
      "args": ["/Users/wiaamhadara/ghost-os-ultimate/mcp_servers/omega_mcp.py"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_MODEL": "ghost-os-architect:latest",
        "MEMORY_URL": "http://localhost:8006",
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
        "ADMIN_TELEGRAM_ID": "${ADMIN_TELEGRAM_ID}"
      }
    }
  }
}
